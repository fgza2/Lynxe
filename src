-- Lynxe Functions -- 
lynxe.functions.GetTool = function(Tool, Handle)
	Tool = Character:FindFirstChildOfClass("Tool") or Player.Backpack:FindFirstChildOfClass("Tool")
	Handle = Tool:FindFirstChild("Handle") or Tool:FindFirstChildOfClass("Part")
	return Tool, Handle
end



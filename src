-- Lynxe Functions -- 
lynxe.functions.GetTool = function(Tool, Handle)
	Tool = Character:FindFirstChildOfClass("Tool") or Player.Backpack:FindFirstChildOfClass("Tool")
	Handle = Tool:FindFirstChild("Handle") or Tool:FindFirstChildOfClass("Part")
	if not Tool or not Handle then return end
	
	if Handle then
		Handle.Massless = true
		Handle.CanCollide = false
		
		pcall(function()
			for i,v in pairs(getconnections(Handle.Changed)) do
				v:Disconnect()
			end
		end)
	end
	return Tool, Handle
end

lynxe.functions.NewConnection = function(key, object, event, callback)
	lynxe._cts[key] = object[event]:Connect(callback)
	return lynxe._cts[key]
end

lynxe.functions.RemoveConnection = function(key)
	lynxe._cts[key]:Disconnect()
	lynxe._cts[key] = nil
end

-- credits to brew methods
lynxe.spoof = function(self, index, property, value)
	if not self._temp[index] then
		self._temp[index] = {}
	end
	
	if self._temp[index][property] then
		return { StatusCode = 409, Message = "Resource already exists" }
	end
	
	self._temp[index][property] = value
	return { StatusCode = 200, Message = "Spoof applied" }
end

lynxe.protectInstance = function(self, instance)
	instance.Name = string.sub(string.gsub(game:GetService("HttpService"):GenerateGUID(false), "-", ""), 1, math.random(25, 30))
	instance.Archivable = false
	lynxe:spoof(instance, "Parent", nil)
	lynxe:spoof(instance, "Name", nil)
	lynxe:spoof(instance, "ClassName", nil)
end


-- Lynxe features --
lynxe.features.Reach = function()
	if not lynxe.configs.combat.reach.enabled then
		if table.find(lynxe._cts, "ReachLoop") then 
			lynxe.functions:RemoveConnection("ReachLoop") 
		end
		return	
	else
		local Tool, Handle = lynxe.functions:GetTool()
		
		lynxe.functions:NewConnection("ReachLoop", RunService, "Heartbeat", function()
			if lynxe.configs.combat.reach.method == "TouchInterest" then
				
				local HandlePos = Handle.Position
				local Forward = Handle.CFrame.LookVector

				for _, Player in pairs(Players:GetPlayers()) do
					if Player.Name == player.Name then continue end

					local character = Player.Character
					if not character then continue end
					local RootPart = character:FindFirstChild("HumanoidRootPart")

					local ToolDistance = (RootPart.Position - HandlePos).Unit
					local dot = Forward:Dot(ToolDistance)

					local clamp = math.clamp(dot, 0, lynxe.configs.combat.reach.range)
					local closest = HandlePos + Forward * clamp

					local Distance = (RootPart.Position - closest).Magnitude

					if Distance <= lynxe.configs.combat.reach.range then
						firetouchinterest(RootPart, Handle, 0)
					else
						firetouchinterest(RootPart, Handle, 1)
					end 
				end
			elseif lynxe.configs.combat.reach.method == "C-Bring(Streamable)" then
				
				local HandlePos = Handle.Position
				local Forward = Handle.CFrame.LookVector

				for _, Player in pairs(Players:GetPlayers()) do
					if Player.Name == player.Name then continue end

					local character = Player.Character
					if not character then continue end
					local RootPart = character:FindFirstChild("HumanoidRootPart")

					local ToolDistance = (RootPart.Position - HandlePos).Unit
					local dot = Forward:Dot(ToolDistance)

					local clamp = math.clamp(dot, 0, lynxe.configs.combat.reach.range)
					local closest = HandlePos + Forward * clamp

					local Distance = (RootPart.Position - closest).Magnitude

					if Distance <= lynxe.configs.combat.reach.range then
						for _, v in pairs(character:GetChildren()) do
							if v:IsA("BasePart") and v.Name == "Left Arm" or v.Name == "Right Arm" then
								pcall(function()
									if v and v.Name == "Left Arm" then
										local LMotor = character:FindFirstChild("Torso")["Left Shoulder"]:Clone()
										v.Parent = workspace
										v.CanCollide = false
										v.Anchored = true
										v:BreakJoints()
										
										local fakeLArm = v:Clone()
										fakeLArm.Parent = character
										fakeLArm.Anchored = false
										LMotor.Part1 = fakeLArm
										LMotor.Parent = character.Torso
										
										v:ClearAllChildren()
										v.Transparency = 1
										v.Parent = character
										v.Name = "B Left Arm"
										
									elseif v and v.Name == "Right Arm" then
										local RMotor = character:FindFirstChild("Torso")["Right Shoulder"]:Clone()
										v.Parent = workspace
										v.CanCollide = false
										v.Anchored = true
										v:BreakJoints()
										
										local fakeRArm = v:Clone()
										fakeRArm.Parent = character
										fakeRArm.Anchored = false
										RMotor.Part1 = fakeRArm
										RMotor.Parent = character.Torso
										
										v:ClearAllChildren()
										v.Transparency = 1
										v.Parent = character
										v.Name = "B Right Arm"
									end
									v.CFrame = Handle.CFrame
								end)
							end
						end
					end 
				end
			elseif lynxe.configs.combat.reach.method == "C-Bring" then
				
				local HandlePos = Handle.Position
				local Forward = Handle.CFrame.LookVector

				for _, Player in pairs(Players:GetPlayers()) do
					if Player.Name == player.Name then continue end

					local character = Player.Character
					if not character then continue end
					local RootPart = character:FindFirstChild("HumanoidRootPart")

					local ToolDistance = (RootPart.Position - HandlePos).Unit
					local dot = Forward:Dot(ToolDistance)

					local clamp = math.clamp(dot, 0, lynxe.configs.combat.reach.range)
					local closest = HandlePos + Forward * clamp

					local Distance = (RootPart.Position - closest).Magnitude

					if Distance <= lynxe.configs.combat.reach.range then
						for _, v in pairs(character:GetChildren()) do
							if v and v:IsA("BasePart") and v.Name == "Right Leg" or v.Name == "Right Arm" or v.Name == "Left Leg" or v.Name == "Left Arm" then
								v:BreakJoints()
								lynxe:Spoof(v, "Anchored", true)
								lynxe:Spoof(v, "CanCollide", false)
								lynxe:Spoof(v, "Transparency", 1)
								v.CFrame = Handle.CFrame
							end
						end
					end 
				end

			end
		end)
	end
end



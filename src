lynxe.features.Reach = function()
	if not lynxe.configs.combat.reach.enabled then
		if table.find(lynxe._cts, "ReachLoop") then 
			lynxe.functions.RemoveConnection("ReachLoop") 
		end
		return	
	else
		lynxe.functions.NewConnection("ReachLoop", RunService, "Heartbeat", function()

			local Tool, Handle = lynxe.functions:GetTool()
			if not Tool or not Handle then return end

			if lynxe.configs.combat.reach.method == "TouchInterest" then

				local HandlePos = Handle.Position
				local Forward = Handle.CFrame.LookVector

				for _, Player in pairs(Players:GetPlayers()) do
					if Player.Name == player.Name then continue end

					local character = Player.Character
					if not character then continue end

					local RootPart = character:FindFirstChild("HumanoidRootPart")
					if not RootPart then continue end

					local ToolDistance = (RootPart.Position - HandlePos).Unit
					local dot = Forward:Dot(ToolDistance)

					local clamp = math.clamp(dot, 0, lynxe.configs.combat.reach.range)
					local closest = HandlePos + Forward * clamp

					local Distance = (RootPart.Position - closest).Magnitude

					--pcall(function()
					if Distance <= lynxe.configs.combat.reach.range then
						firetouchinterest(RootPart, Handle, 0)
						task.wait(.25)
						firetouchinterest(RootPart, Handle, 1)
					end
					--end)
				end
			elseif lynxe.configs.combat.reach.method == "C-Bring(Streamable)" then

				local HandlePos = Handle.Position
				local Forward = Handle.CFrame.LookVector

				for _, Player in pairs(Players:GetPlayers()) do
					if Player.Name == player.Name then continue end

					local character = Player.Character
					if not character then continue end

					local RootPart = character:FindFirstChild("HumanoidRootPart")
					if not RootPart then continue end

					local ToolDistance = (RootPart.Position - HandlePos).Unit
					local dot = Forward:Dot(ToolDistance)

					local clamp = math.clamp(dot, 0, lynxe.configs.combat.reach.range)
					local closest = HandlePos + Forward * clamp

					local Distance = (RootPart.Position - closest).Magnitude

					local function SpoofLimb(limbName, motorName, prefix)
						local limb = character:FindFirstChild(limbName)
						if not limb then return end

						if character:FindFirstChild(prefix .. " " .. limbName) then return end

						local motor = character.Torso[motorName]:Clone()
						limb.Parent = workspace
						limb.CanCollide = false
						limb.Anchored = true
						limb:BreakJoints()

						local fakeLimb = limb:Clone()
						fakeLimb.Parent = character
						fakeLimb.Anchored = false
						motor.Part1 = fakeLimb
						motor.Parent = character.Torso

						limb:ClearAllChildren()
						limb.Transparency = 1
						limb.Parent = character
						limb.Name = prefix .. " " .. limbName
					end

					if Distance <= lynxe.configs.combat.reach.range then
						for _, v in pairs(character:GetChildren()) do
							pcall(function()
								if v:IsA("BasePart") and (v.Name == "Right Leg" or v.Name == "Left Leg" or v.Name == "Left Arm") then

									local MotorMap = {["Right Leg"] = "Right Hip", ["Left Leg"] = "Left Hip", ["Left Arm"] = "Left Shoulder"}
									SpoofLimb(v.Name, MotorMap[v.Name], "O")
								end

								if v:IsA("BasePart") and (v.Name == "O Right Leg" or v.Name == "O Left Leg" or v.Name == "O Left Arm") then
									v.CFrame = Handle.CFrame
								end
							end)
						end
					end 
				end
			elseif lynxe.configs.combat.reach.method == "C-Bring" then

				local HandlePos = Handle.Position
				local Forward = Handle.CFrame.LookVector

				for _, Player in pairs(Players:GetPlayers()) do
					if Player.Name == player.Name then continue end

					local character = Player.Character
					if not character then continue end

					local RootPart = character:FindFirstChild("HumanoidRootPart")
					if not RootPart then continue end

					local ToolDistance = (RootPart.Position - HandlePos).Unit
					local dot = Forward:Dot(ToolDistance)

					local clamp = math.clamp(dot, 0, lynxe.configs.combat.reach.range)
					local closest = HandlePos + Forward * clamp

					local Distance = (RootPart.Position - closest).Magnitude

					if Distance <= lynxe.configs.combat.reach.range then
						for _, v in pairs(character:GetChildren()) do
							if v and v:IsA("BasePart") and v.Name == "Right Leg" or v.Name == "Right Arm" or v.Name == "Left Leg" or v.Name == "Left Arm" then
								v:BreakJoints()
								v.Anchored = true
								v.CanCollide = false
								v.Transparency = 1
								v.CFrame = Handle.CFrame
							end
						end
					end
				end
				----
			end
		end)
	end
end

lynxe.features.tank = function(self)
	for _, Part in pairs(player.Character:GetChildren()) do
		if Part:IsA("BasePart") then
			lynxe.spoof(Part, "CanTouch", true)
			Part.CanTouch = lynxe.configs.combat.tank.enabled
		end
	end
end



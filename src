lynxe.functions.collect = function()
	task.spawn(function()
		while task.wait(30) do
			local cleaned = 0

			for index, _ in pairs(lynxe._temp) do
				if typeof(index) == "Instance" and index.Parent == nil then
					lynxe._temp[index] = nil
					cleaned += 1
				end
			end
		end
	end)
end
lynxe.functions:collect()


if lynxe.configs.spoofMethod == "metamethod" then
	if hookmetamethod then
		local old; old = hookmetamethod(game, "__index", function(i, v)
			if not checkcaller() then
				local instTable = lynxe._temp[i]
				if instTable and instTable[v] ~= nil then
					return instTable[v]
				end
			end
			return old(i, v)
		end)
	end
elseif lynxe.configs.spoofMethod == "metatable" then
	if getrawmetatable and setreadonly and newcclosure then
		local mt = getrawmetatable(game)
		setreadonly(mt, false)
		local oldIndex = mt.__index

		mt.__index = newcclosure(function(i, v)
			if not checkcaller() then
				local instTable = lynxe._temp[i]
				if instTable and instTable[v] ~= nil then
					return instTable[v]
				end
			end
			return oldIndex(i, v)
		end)
	end
end
